{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CofiswarmAgent",
  "type": "object",
  "required": [
    "name",
    "port",
    "engine"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "port": {
      "type": "integer"
    },
    "engine": {
      "type": "string",
      "enum": [
        "llama",
        "mlx",
        "docker"
      ]
    },
    "description": {
      "type": "string"
    },
    "backend": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "draft_model": {
      "type": "string"
    },
    "draft_max": {
      "type": "integer"
    },
    "inference_backend": {
      "type": "string"
    },
    "server_group": {
      "type": "string"
    },
    "system_prompt": {
      "type": "string"
    },
    "max_tokens": {
      "type": "integer"
    },
    "context": {
      "type": "integer"
    },
    "ctx_cap": {
      "type": "integer"
    },
    "flash_attn": {
      "type": "boolean"
    },
    "extra_args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kv_cache_type": {
      "type": "string",
      "description": "KV cache quantization, e.g. \"q4_0\" or \"q4_0,q8_0\" (k,v)."
    },
    "rope_scaling": {
      "type": "string",
      "enum": [
        "linear",
        "yarn"
      ],
      "description": "RoPE context-extension method."
    },
    "rope_freq_base": {
      "type": "number"
    },
    "rope_freq_scale": {
      "type": "number"
    },
    "yarn_orig_ctx": {
      "type": "integer"
    },
    "yarn_ext_factor": {
      "type": "number"
    },
    "turbo_quant": {
      "type": "boolean",
      "description": "Route KV cache to the TurboQuant pilot cache type."
    },
    "use_rag": {
      "type": "boolean",
      "description": "Inject retrieved RAG context into this agent's prompt (per-agent targeting)."
    },
    "rag_top_k": {
      "type": "integer",
      "description": "Number of chunks to retrieve for this agent when use_rag is set."
    },
    "rag_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Restrict this agent's RAG retrieval to these memory/document kinds."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}